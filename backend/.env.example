# Service
PORT=10004
HOST=127.0.0.1

# Storage paths are resolved relative to backend/ when not absolute.
DATA_DIR=./data
VAULT_PATH=./data/secretbase.enc
BACKUP_DIR=./data/backups/
SETTINGS_PATH=./settings.json

# Optional AI parsing. Leave DEEPSEEK_API_KEY empty to disable AI features.
AI_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
AI_API_URL=https://api.deepseek.com/chat/completions

# CORS. Use a specific HTTPS origin in public production deployments.
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
