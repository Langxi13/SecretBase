# Service
PORT=10004
HOST=127.0.0.1

# Storage paths are resolved relative to backend/ when not absolute.
DATA_DIR=./data
VAULT_PATH=./data/secretbase.enc
BACKUP_DIR=./data/backups/
SETTINGS_PATH=./data/settings.json

# Optional AI settings are configured after unlock from the application UI.
# The API key is stored in encrypted data/secure-settings.enc, not in this file.

# CORS. Use a specific HTTPS origin in public production deployments.
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
