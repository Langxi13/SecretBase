<?xml version="1.0" encoding="utf-8"?>
<!--
  Files extracted from an Internet-downloaded ZIP can inherit Mark-of-the-Web.
  This permits pythonnet's managed runtime assembly to load without asking users
  to manually unblock every file. This file must sit next to SecretBase.exe.
-->
<configuration>
  <runtime>
    <loadFromRemoteSources enabled="true" />
  </runtime>
</configuration>
